<?xml version="1.0" encoding="UTF-8" ?>
<!-- XL300 Fast DDS QoS profiles = the named profiles from DDS_Topic_Contract §2.
     Apply by setting  FASTRTPS_DEFAULT_PROFILES_FILE=/etc/xl300/xl300_profiles.xml
     then create entities BY PROFILE NAME in code (see dds/README.md).

     IMPORTANT (RxO rule): a DataWriter and DataReader only connect if their QoS are
     COMPATIBLE (reader's request <= writer's offer). Keep each topic's writer+reader
     on the matching profile below or they silently won't communicate.

     data_sharing=OFF on every profile: Fast DDS's Data Sharing feature (zero-copy via
     /dev/shm) auto-negotiates whenever two participants' GUID prefixes look like the
     "same host" — but each devcontainer is its own Docker container with an isolated
     /dev/shm, so one participant advertises a shm segment the other can never open
     ("Failed to open segment ... No such file or directory", HISTORY_DATASHARING_*).
     The real deployment is multi-node anyway (separate physical CPUs per Tier-0
     replica) where data sharing could never apply, so turning it off costs nothing in
     production and fixes same-host-looking-but-isolated dev/test containers too. -->
<dds xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
  <profiles>

    <!-- ================= PARTICIPANT (Domain 0) ================================
         Start with SIMPLE discovery (multicast) — zero config, "just works" on a LAN
         and is perfect for the VM lab. Switch to the Discovery Server (CLIENT) block
         at the bottom later for scale (contract §2.0). -->
    <participant profile_name="xl300_domain0" is_default_profile="true">
      <domainId>0</domainId>
      <rtps>
        <builtin>
          <discovery_config>
            <discoveryProtocol>SIMPLE</discoveryProtocol>
          </discovery_config>
          <!-- Cross-container discovery on Docker Desktop: SPDP MULTICAST (239.255.0.1)
               does NOT traverse between separate --network=host containers on Docker
               Desktop for Windows (confirmed 2026-07-15: svp_manager publishes sensors/svp,
               but nss in another container received nothing). Adding an initial peer makes
               Fast DDS ALSO announce via UNICAST to that address's participant-port range,
               bypassing multicast. All --network=host containers share the Docker Desktop
               VM's loopback, so 127.0.0.1 reaches every co-located participant. Harmless on
               a real LAN (multicast still runs too); this only ADDS a unicast bootstrap.
               Production direction is the same idea at scale -- Discovery Server for the
               multi-node k3s fabric where multicast is likewise constrained (contract §2.0). -->
          <initialPeersList>
            <locator>
              <udpv4>
                <address>127.0.0.1</address>
              </udpv4>
            </locator>
          </initialPeersList>
        </builtin>
      </rtps>
    </participant>

    <!-- ================= DATA WRITER PROFILES ================================== -->

    <!-- STATE: latest-value streams (nav/core, feedback/*). RELIABLE, EXCLUSIVE. -->
    <data_writer profile_name="STATE">
      <qos>
        <reliability><kind>RELIABLE</kind></reliability>
        <durability><kind>VOLATILE</kind></durability>
        <ownership><kind>EXCLUSIVE</kind></ownership>
        <!-- deadline = 2x period; nav/core @50Hz -> 40 ms -->
        <deadline><period><sec>0</sec><nanosec>40000000</nanosec></period></deadline>
        <!-- ownership_strength is set PER-REPLICA at runtime (primary 100 > standby 90);
             see README. You may also hard-code it here per deployment. -->
        <data_sharing><kind>OFF</kind></data_sharing>
      </qos>
      <topic><historyQos><kind>KEEP_LAST</kind><depth>1</depth></historyQos></topic>
    </data_writer>

    <!-- CONTROL: commands (ctrl/*). RELIABLE + TRANSIENT_LOCAL + EXCLUSIVE.
         announcement_period MUST be < lease_duration (DDS liveliness QoS invariant,
         enforced by Fast DDS's check_qos — omitting it left the implicit default at
         or above lease_duration, which made create_datawriter_with_profile() silently
         fail this profile and fall back to QOS_DEFAULT). Set to lease_duration/3 so a
         single lost announcement doesn't expire the lease. -->
    <data_writer profile_name="CONTROL">
      <qos>
        <reliability><kind>RELIABLE</kind></reliability>
        <durability><kind>TRANSIENT_LOCAL</kind></durability>
        <ownership><kind>EXCLUSIVE</kind></ownership>
        <deadline><period><sec>0</sec><nanosec>40000000</nanosec></period></deadline>
        <liveliness><kind>AUTOMATIC</kind><lease_duration><sec>0</sec><nanosec>200000000</nanosec></lease_duration><announcement_period><sec>0</sec><nanosec>60000000</nanosec></announcement_period></liveliness>
        <data_sharing><kind>OFF</kind></data_sharing>
      </qos>
      <topic><historyQos><kind>KEEP_LAST</kind><depth>1</depth></historyQos></topic>
    </data_writer>

    <!-- SAFETY: safety/state. RELIABLE + TRANSIENT_LOCAL (late joiner learns state).
         Same announcement_period < lease_duration fix as CONTROL above. -->
    <data_writer profile_name="SAFETY">
      <qos>
        <reliability><kind>RELIABLE</kind></reliability>
        <durability><kind>TRANSIENT_LOCAL</kind></durability>
        <ownership><kind>EXCLUSIVE</kind></ownership>
        <deadline><period><sec>0</sec><nanosec>50000000</nanosec></period></deadline>
        <liveliness><kind>AUTOMATIC</kind><lease_duration><sec>0</sec><nanosec>100000000</nanosec></lease_duration><announcement_period><sec>0</sec><nanosec>30000000</nanosec></announcement_period></liveliness>
        <data_sharing><kind>OFF</kind></data_sharing>
      </qos>
      <topic><historyQos><kind>KEEP_LAST</kind><depth>1</depth></historyQos></topic>
    </data_writer>

    <!-- SENSOR: raw high-rate streams (sensors/*). BEST_EFFORT (stale = useless). -->
    <data_writer profile_name="SENSOR">
      <qos>
        <reliability><kind>BEST_EFFORT</kind></reliability>
        <durability><kind>VOLATILE</kind></durability>
        <ownership><kind>SHARED</kind></ownership>
        <data_sharing><kind>OFF</kind></data_sharing>
      </qos>
      <topic><historyQos><kind>KEEP_LAST</kind><depth>1</depth></historyQos></topic>
    </data_writer>

    <!-- HEALTH: heartbeats (health/*). BEST_EFFORT + deadline = failure detector. -->
    <data_writer profile_name="HEALTH">
      <qos>
        <reliability><kind>BEST_EFFORT</kind></reliability>
        <durability><kind>VOLATILE</kind></durability>
        <ownership><kind>SHARED</kind></ownership>
        <deadline><period><sec>1</sec><nanosec>0</nanosec></period></deadline>
        <data_sharing><kind>OFF</kind></data_sharing>
      </qos>
      <topic><historyQos><kind>KEEP_LAST</kind><depth>1</depth></historyQos></topic>
    </data_writer>

    <!-- ================= DATA READER PROFILES (mirror the writers) ============= -->
    <data_reader profile_name="STATE">
      <qos>
        <reliability><kind>RELIABLE</kind></reliability>
        <durability><kind>VOLATILE</kind></durability>
        <ownership><kind>EXCLUSIVE</kind></ownership>
        <deadline><period><sec>0</sec><nanosec>40000000</nanosec></period></deadline>
        <data_sharing><kind>OFF</kind></data_sharing>
      </qos>
      <topic><historyQos><kind>KEEP_LAST</kind><depth>1</depth></historyQos></topic>
    </data_reader>

    <data_reader profile_name="CONTROL">
      <qos>
        <reliability><kind>RELIABLE</kind></reliability>
        <durability><kind>TRANSIENT_LOCAL</kind></durability>
        <ownership><kind>EXCLUSIVE</kind></ownership>
        <deadline><period><sec>0</sec><nanosec>40000000</nanosec></period></deadline>
        <liveliness><kind>AUTOMATIC</kind><lease_duration><sec>0</sec><nanosec>200000000</nanosec></lease_duration><announcement_period><sec>0</sec><nanosec>60000000</nanosec></announcement_period></liveliness>
        <data_sharing><kind>OFF</kind></data_sharing>
      </qos>
      <topic><historyQos><kind>KEEP_LAST</kind><depth>1</depth></historyQos></topic>
    </data_reader>

    <data_reader profile_name="SAFETY">
      <qos>
        <reliability><kind>RELIABLE</kind></reliability>
        <durability><kind>TRANSIENT_LOCAL</kind></durability>
        <ownership><kind>EXCLUSIVE</kind></ownership>
        <deadline><period><sec>0</sec><nanosec>50000000</nanosec></period></deadline>
        <liveliness><kind>AUTOMATIC</kind><lease_duration><sec>0</sec><nanosec>100000000</nanosec></lease_duration><announcement_period><sec>0</sec><nanosec>30000000</nanosec></announcement_period></liveliness>
        <data_sharing><kind>OFF</kind></data_sharing>
      </qos>
      <topic><historyQos><kind>KEEP_LAST</kind><depth>1</depth></historyQos></topic>
    </data_reader>

    <data_reader profile_name="SENSOR">
      <qos>
        <reliability><kind>BEST_EFFORT</kind></reliability>
        <durability><kind>VOLATILE</kind></durability>
        <data_sharing><kind>OFF</kind></data_sharing>
      </qos>
      <topic><historyQos><kind>KEEP_LAST</kind><depth>1</depth></historyQos></topic>
    </data_reader>

    <data_reader profile_name="HEALTH">
      <qos>
        <reliability><kind>BEST_EFFORT</kind></reliability>
        <durability><kind>VOLATILE</kind></durability>
        <deadline><period><sec>1</sec><nanosec>0</nanosec></period></deadline>
        <data_sharing><kind>OFF</kind></data_sharing>
      </qos>
      <topic><historyQos><kind>KEEP_LAST</kind><depth>1</depth></historyQos></topic>
    </data_reader>

    <!-- ============ OPTIONAL: Discovery Server (enable later for scale) =========
    Replace the SIMPLE participant above with this CLIENT one. Run 2 servers:
      fastdds discovery -i 0 -l 192.168.56.11 -p 11811   (on cpu-1)
      fastdds discovery -i 1 -l 192.168.56.13 -p 11811   (on cpu-3)
    <participant profile_name="xl300_domain0" is_default_profile="true">
      <domainId>0</domainId>
      <rtps><builtin><discovery_config>
        <discoveryProtocol>CLIENT</discoveryProtocol>
        <discoveryServersList>
          <RemoteServer prefix="44.53.00.5f.45.50.52.4f.53.49.4d.41">
            <metatrafficUnicastLocatorList>
              <locator><udpv4><address>192.168.56.11</address><port>11811</port></udpv4></locator>
            </metatrafficUnicastLocatorList>
          </RemoteServer>
        </discoveryServersList>
      </discovery_config></builtin></rtps>
    </participant>
    ========================================================================== -->

  </profiles>
</dds>
